# ──────────────────────────────────────────────
# Provinci — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.
# ──────────────────────────────────────────────


# ____ Data seeder  ____________________________
DEV=

# Debug log file path. Logs all operations (network, VPS, OCI) to file + stdout.
# Only active when DEV=true. Default: none (stdout only).
LOG_FILE=/app/logs/provinci.log

# ─── Login Security ──────────────────────────

# Maximum failed login attempts before account lockout.
# Default: 5
LOGIN_MAX_ATTEMPTS=5

# Lockout duration in minutes after exceeding max attempts.
# Default: 15
LOGIN_LOCKOUT_MINUTES=15

# ─── Required ─────────────────────────────────

# Master encryption key for the SQLite database.
# Generate with: openssl rand -hex 32
# KEEP THIS SAFE — if you lose it, the database is unrecoverable.
DB_ENCRYPTION_KEY=

# ─── Networking ───────────────────────────────

# Comma-separated list of allowed CORS origins.
# Set this to your dashboard domain(s) in production.
# Defaults to http://localhost:5173,http://localhost:10001 if left empty.
# Example for production behind Traefik:
#   CORS_ORIGINS=https://provinci.llassingan.web.id
CORS_ORIGINS=

# ─── Frontend (only needed when running outside Docker) ───

# Backend URL that Vite proxies /api requests to.
# Only used by the Vite dev server (npm run dev).
# Defaults to http://localhost:10000 if left empty.
VITE_API_TARGET=http://localhost:10000

# Override the API base path from /api to a full URL.
# Only needed for production builds where the Vite proxy is absent.
# Example: https://api-provinci.llassingan.web.id/api
VITE_API_BASE_URL=
